\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Hierarchical Affordance-Aware RAG (HAA-RAG{}) pipeline. Experiences are progressively filtered through three levels: category matching, affordance scoring, and visual re-ranking, reducing 116 candidates to 3 physically appropriate strategies. Right annotations show candidate count at each stage.}}{3}{figure.caption.2}\protected@file@percent }
\newlabel{fig:haarag}{{2}{3}{Hierarchical Affordance-Aware RAG (\haarag {}) pipeline. Experiences are progressively filtered through three levels: category matching, affordance scoring, and visual re-ranking, reducing 116 candidates to 3 physically appropriate strategies. Right annotations show candidate count at each stage}{figure.caption.2}{}}
